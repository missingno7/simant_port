__pycache__/
*.pyc
.pytest_cache/
.idea/
.claude/
# Original game files are never committed (dos_re convention).
assets/
# Scratch evidence; promoted oracles live in artifacts/test_oracles/ (tracked).
artifacts/*
!artifacts/test_oracles/
# Snapshots are scratch evidence unless promoted.
artifacts/snapshots/
# Machine-lifted hooks are regenerated scratch (status LIFTED, not recovered
# source): scripts/liftverify.py re-emits them.  A lift only enters the repo
# once REFACTORED into simant/recovered/ with its oracle test.
simant/lifted/
# Locally recorded demos (promote a repro into artifacts/test_oracles/ to keep).
*.jsonl
